{
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml" }]
    },
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain" }]
    }
  ],
  "rewrites": [
    { "source": "/((?!sitemap\\.xml|robots\\.txt|favicon\\.png|logo\\.png|placeholder\\.svg|site\\.webmanifest|_redirects|_headers).*)", "destination": "/index.html" }
  ]
}
